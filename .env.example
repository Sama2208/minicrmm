# Supabase ulanish sozlamalari.
# Bu fayldan nusxa oling: cp .env.example .env  va qiymatlarni to'ldiring.
# VITE_ prefiksli o'zgaruvchilar brauzerga uzatiladi — faqat publishable (anon)
# kalitlardan foydalaning, hech qachon service_role kalitini bu yerga yozmang.

# Supabase loyiha ID si (masalan: abcdefghijklmnop)
SUPABASE_PROJECT_ID=
VITE_SUPABASE_PROJECT_ID=

# Supabase REST/Realtime URL manzili (masalan: https://<project>.supabase.co)
SUPABASE_URL=
VITE_SUPABASE_URL=

# Publishable (anon) kalit — brauzerda ishlatish uchun xavfsiz
SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
